@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

@section Styles {
    <style>
        .product-img { width: 50px; height: 50px; object-fit: cover; border-radius: 4px; }
        .badge-stock { padding: 5px 10px; border-radius: 20px; font-size: 0.8rem; }
    </style>
}

<div class="main">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Quản lý sản phẩm</h3>
        <button class="btn btn-primary" onclick="openCreateProductModal()">
            <i class="fa fa-plus me-2"></i> Thêm sản phẩm mới
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá từ</th>
                            <th>Tồn kho</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="productData"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Thêm/Sửa -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="productModalLabel">Sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="productForm">
                    <input type="hidden" id="modal_SanPhamId" value="0">
                    <div class="mb-3">
                        <label class="form-label">Tên sản phẩm</label>
                        <input type="text" id="modal_TenSanPham" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Danh mục</label>
                        <select id="modal_MaDanhMuc" class="form-select" required>
                            <option value="">Chọn danh mục</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea id="modal_MoTa" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="saveProduct()">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            loadProducts();
            loadCategories();
        });

        async function loadProducts() {
            try {
                const res = await fetch('/api/product');
                if (!res.ok) throw new Error("Không thể tải dữ liệu");
                const products = await res.json();
                const tbody = document.getElementById('productData');
                
                tbody.innerHTML = products.map(p => `
                    <tr>
                        <td><img src="${p.hinhAnhDaiDien || '/img/no-image.png'}" class="product-img" onerror="this.src='/img/no-image.png'"></td>
                        <td><strong>${p.tenSanPham}</strong></td>
                        <td>${p.tenDanhMuc}</td>
                        <td class="text-danger fw-bold">${p.giaGoc ? p.giaGoc.toLocaleString() : 0}đ</td>
                        <td><span class="badge ${p.tongSoLuongTon > 0 ? 'bg-info' : 'bg-danger'}">${p.tongSoLuongTon}</span></td>
                        <td><span class="badge ${p.trangThai ? 'bg-success' : 'bg-secondary'}">${p.trangThai ? 'Kinh doanh' : 'Ngừng'}</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="location.href='/Admin/Product/Detail/${p.sanPhamId}'"><i class="fa fa-eye"></i></button>
                            <button class="btn btn-sm btn-outline-secondary" onclick="openEditProductModal(${p.sanPhamId})"><i class="fa fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteProduct(${p.sanPhamId})"><i class="fa fa-trash"></i></button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error(error);
                document.getElementById('productData').innerHTML = '<tr><td colspan="7" class="text-center text-danger">Lỗi tải dữ liệu</td></tr>';
            }
        }

        async function loadCategories() {
            const res = await fetch('/api/danhmuc');
            const cats = await res.json();
            const select = document.getElementById('modal_MaDanhMuc');
            select.innerHTML += cats.map(c => `<option value="${c.maDanhMuc}">${c.tenDanhMuc}</option>`).join('');
        }

        function openCreateProductModal() {
            document.getElementById('productForm').reset();
            document.getElementById('modal_SanPhamId').value = "0";
            new bootstrap.Modal(document.getElementById('productModal')).show();
        }

        async function deleteProduct(id) {
            if (!confirm("Xác nhận xóa sản phẩm này?")) return;
            const res = await fetch(`/api/product/${id}`, { method: 'DELETE' });
            if (res.ok) { alert("Xóa thành công!"); loadProducts(); }
        }

        async function saveProduct() {
            // Logic lưu ở đây tương tự như trước nhưng hướng về endpoint /api/product
        }
    </script>
}
