@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="main">
    <div class="header mb-4">
        <h3>Quản lý đơn hàng</h3>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="orderData"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            loadOrders();
        });

        async function loadOrders() {
            try {
                const res = await fetch('/api/order');
                if (!res.ok) throw new Error("Không thể tải đơn hàng");
                const orders = await res.json();
                const tbody = document.getElementById('orderData');
                
                tbody.innerHTML = orders.map(o => `
                    <tr>
                        <td><strong>${o.maDonHang || "#" + o.id}</strong></td>
                        <td>${o.hoTen}</td>
                        <td>${new Date(o.ngayThanhToan).toLocaleDateString('vi-VN')}</td>
                        <td class="text-danger fw-bold">${o.tongTien.toLocaleString()}đ</td>
                        <td><span class="badge bg-secondary">${o.trangThai}</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="location.href='/Admin/Order/Detail/${o.id}'">
                                <i class="fa fa-eye"></i> Chi tiết
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error(error);
                document.getElementById('orderData').innerHTML = '<tr><td colspan="6" class="text-center text-danger">Lỗi tải dữ liệu đơn hàng</td></tr>';
            }
        }
    </script>
}
