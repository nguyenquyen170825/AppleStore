@model DUANCUAHANGAPPLE.ViewModels.DanhMucVM
@{
    ViewData["Title"] = "Thêm danh mục mới";
}

@section Styles {
    <style>
        .form-card {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            padding: 2rem;
            max-width: 600px;
            margin: 0 auto;
        }
        .form-label {
            font-weight: 600;
            color: #495057;
            margin-bottom: 0.5rem;
        }
        .form-control {
            height: 48px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            padding: 10px 15px;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        }
        .btn-save {
            height: 48px;
            border-radius: 8px;
            font-weight: 600;
            background: #0d6efd;
            border: none;
            color: white;
            width: 100%;
            margin-top: 1rem;
            transition: transform 0.2s;
        }
        .btn-save:hover { background: #0b5ed7; transform: translateY(-1px); }
        .btn-back {
            text-decoration: none;
            color: #6c757d;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            margin-bottom: 1rem;
            transition: color 0.2s;
        }
        .btn-back:hover { color: #212529; }
    </style>
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <a class="btn-back" href="/Admin/DanhMuc/Index">
                <i class="fa fa-arrow-left me-2"></i> Quay lại danh sách
            </a>
            
            <div class="form-card">
                <div class="text-center mb-4">
                    <h3 class="fw-bold">Thêm danh mục mới</h3>
                    <p class="text-muted">Nhập thông tin để tạo danh mục sản phẩm mới</p>
                </div>

                <form id="createDanhMucForm">
                    <div class="mb-3">
                        <label class="form-label">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="TenDanhMuc" type="text" id="tenDanhMuc" class="form-control" required placeholder="Ví dụ: iPhone, MacBook..." />
                        <span asp-validation-for="TenDanhMuc" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Trạng thái hiển thị</label>
                        <select asp-for="TrangThai" id="trangThai" class="form-select" style="height: 48px; border-radius: 8px;">
                            <option value="true">Hiển thị (Hoạt động)</option>
                            <option value="false">Tạm ẩn</option>
                        </select>
                    </div>

                    <div id="message" class="alert d-none mb-3" role="alert"></div>

                    <button type="submit" class="btn-save shadow">
                        <i class="fa fa-save me-2"></i> Lưu danh mục
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showMessage(text, isSuccess = false) {
            const msgDiv = document.getElementById('message');
            msgDiv.textContent = text;
            msgDiv.className = `alert ${isSuccess ? 'alert-success' : 'alert-danger'}`;
            msgDiv.classList.remove('d-none');
        }

        document.getElementById('createDanhMucForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i> Đang lưu...';

            const danhMucData = {
                tenDanhMuc: document.getElementById('tenDanhMuc').value,
                trangThai: document.getElementById('trangThai').value === 'true'
            };

            try {
                const response = await fetch('/api/danhmuc', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(danhMucData)
                });

                if (response.ok) {
                    showMessage('Thêm danh mục thành công!', true);
                    setTimeout(() => {
                        window.location.href = '/Admin/DanhMuc/Index';
                    }, 1200);
                } else {
                    const errorData = await response.json();
                    showMessage(errorData.message || 'Thêm thất bại! Vui lòng kiểm tra lại.');
                }
            } catch (error) {
                showMessage('Lỗi kết nối đến máy chủ!');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-save me-2"></i> Lưu danh mục';
            }
        });
    </script>
}
