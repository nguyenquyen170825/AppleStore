@{
    ViewData["Title"] = "Quản lý danh mục";
}

@section Styles {
    <link rel="stylesheet" href="/css/home/Admin/danhmuc.css" asp-append-version="true" />
}

<div class="main">
    <div class="header">
        <h3>Quản lý danh mục</h3>
        <a class="add-btn" href="/Admin/DanhMuc/Create">
            + Thêm danh mục mới
        </a>
    </div>
    <div class="filter-bar">
        <input type="text" id="searchInput" placeholder="Tìm tên danh mục..." />
        <select id="statusFilter">
            <option value="">Tất cả trạng thái</option>
            <option value="true">Hoạt động</option>
            <option value="false">Tạm ẩn</option>
        </select>
        <button class="btn-search">Tìm</button>
        <button class="btn-reset">Làm mới</button>
    </div>

    <div id="message" style="margin-bottom: 15px; display: none; font-weight: 500;"></div>
    <div class="table-wrapper">
    <table>
        <thead>
            <tr>
                <th>Mã danh mục</th>
                <th>Tên danh mục</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody id="danhMucData">
        </tbody>
    </table>
</div>
</div>
@section Scripts {
    <script>
        function showMessage(text, isSuccess = false) {
            const msgDiv = document.getElementById('message');
            msgDiv.textContent = text;
            msgDiv.style.color = isSuccess ? '#28a745' : '#e53935';
            msgDiv.style.display = 'block';
            setTimeout(() => { msgDiv.style.display = 'none'; }, 3000);
        }

        async function fetchDanhMucs() {
            try {
                const searchKeyword = document.getElementById('searchInput').value.trim().toLowerCase();
                const statusValue = document.getElementById('statusFilter').value;

                const response = await fetch('/api/danhmuc');
                if (!response.ok) throw new Error(`Lỗi HTTP: ${response.status}`);

                let danhmucs = await response.json();

                if (searchKeyword) {
                    danhmucs = danhmucs.filter(d => 
                        (d.tenDanhMuc && d.tenDanhMuc.toLowerCase().includes(searchKeyword))
                    );
                }

                if (statusValue !== "") {
                    const isStatusTrue = statusValue === "true";
                    danhmucs = danhmucs.filter(d => d.trangThai === isStatusTrue);
                }

                const tableBody = document.getElementById('danhMucData');

                if (!danhmucs || danhmucs.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="4" style="text-align: center;">Chưa có danh mục nào!</td></tr>';
                    return;
                }

                tableBody.innerHTML = danhmucs.map(d => {
                    return `
                    <tr>
                        <td>#${d.maDanhMuc}</td>
                        <td><strong>${d.tenDanhMuc || "Không tên"}</strong></td>
                        <td>
                           <span class="badge ${d.trangThai ? "bg-success" : "bg-danger"}">
                                ${d.trangThai ? "Hoạt động" : "Tạm ẩn"}
                           </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn btn-outline-primary btn-sm me-1" onclick="location.href='/Admin/DanhMuc/Edit/${d.maDanhMuc}'"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteDanhMuc(${d.maDanhMuc})"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    `;
                }).join('');

            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('danhMucData').innerHTML =
                    `<tr><td colspan="4" style="color:red; text-align: center;">Lỗi kết nối API. Vui lòng kiểm tra lại server.</td></tr>`;
            }
        }

        async function deleteDanhMuc(id) {
            if (!confirm("Xác nhận xóa danh mục này?")) return;
            try {
                const response = await fetch(`/api/danhmuc/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    showMessage("Đã xóa thành công!", true);
                    fetchDanhMucs();
                } else {
                    const errorData = await response.json();
                    showMessage("Xóa thất bại: " + (errorData.detail || errorData.message || "Lỗi không xác định"));
                }
            } catch (error) {
                console.error("Lỗi xóa:", error);
                showMessage("Lỗi kết nối hoặc sự cố mạng!");
            }
        }

        document.addEventListener("DOMContentLoaded", fetchDanhMucs);
        document.querySelector('.btn-search').addEventListener('click', fetchDanhMucs);
        document.getElementById('searchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') fetchDanhMucs();
        });
        document.getElementById('statusFilter').addEventListener('change', fetchDanhMucs);
        document.querySelector('.btn-reset').addEventListener('click', function () {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';
            fetchDanhMucs();
        });
    </script>
}
