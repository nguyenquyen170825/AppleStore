@{
    ViewData["Title"] = "Quản lý Bài viết";
}

@section Styles {
    <link rel="stylesheet" href="~/css/danhmuc.css" asp-append-version="true" />
}

<div class="main">
    <div class="header">
        <h3>Quản lý Bài viết</h3>
        <a class="add-btn" href="/News/Create">
            + Thêm bài viết mới
        </a>
    </div>

    <div id="message" style="margin-bottom: 15px; display: none; font-weight: 500;"></div>
    
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Hình ảnh</th>
                    <th>Tiêu đề</th>
                    <th>Nguồn / Tác giả</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="newsData">
                <tr><td colspan="6" style="text-align: center;">Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function showMessage(text, isSuccess = false) {
            const msgDiv = document.getElementById('message');
            msgDiv.textContent = text;
            msgDiv.style.color = isSuccess ? '#28a745' : '#e53935';
            msgDiv.style.display = 'block';
            setTimeout(() => { msgDiv.style.display = 'none'; }, 3000);
        }

        async function fetchNews() {
            try {
                const response = await fetch('/api/news');
                if (!response.ok) throw new Error(`Lỗi HTTP: ${response.status}`);

                const newsList = await response.json();
                const tableBody = document.getElementById('newsData');

                if (!newsList || newsList.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="6" style="text-align: center;">Chưa có bài viết nào!</td></tr>';
                    return;
                }

                tableBody.innerHTML = newsList.map(n => {
                    const id = n.id;
                    const title = n.tieude || "Không có tiêu đề";
                    const source = n.source || "N/A";
                    const image = n.imageUrl || "https://via.placeholder.com/80";
                    
                    const createdDate = n.ngaytao ? new Date(n.ngaytao).toLocaleDateString('vi-VN') : "N/A";

                    return `
                    <tr>
                        <td>${id}</td>
                        <td><img src="${image}" style="width:80px; height:50px; object-fit:cover; border-radius:4px;" alt="Hình ảnh"></td>
                        <td><strong>${title}</strong></td>
                        <td>${source}</td>
                        <td>${createdDate}</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-edit" onclick="location.href='/News/Edit/${id}'" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn-delete" onclick="deleteNews(${id})" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    `;
                }).join('');
            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('newsData').innerHTML = `<tr><td colspan="6" style="color:red; text-align: center;">Lỗi kết nối API. Không thể tải dữ liệu.</td></tr>`;
            }
        }

        async function deleteNews(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa bài viết này không?")) return;
            
            try {
                const response = await fetch(`/api/news/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    showMessage("Xóa bài viết thành công!", true);
                    fetchNews(); 
                } else {
                    showMessage("Xóa thất bại! Vui lòng thử lại.");
                }
            } catch (error) {
                console.error("Lỗi xóa:", error);
                showMessage("Lỗi kết nối đến máy chủ.");
            }
        }

        document.addEventListener("DOMContentLoaded", fetchNews);
    </script>
}
