@{
    ViewData["Title"] = "Quản lý khách hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/danhmuc.css" asp-append-version="true" />
}

<div class="main">
    <div class="header">
        <h3>Quản lý người dùng</h3>
        <a class="add-btn" href="/User/Create">
            + Thêm người dùng mới
        </a>
    </div>
    <div class="filter-bar">
        <input type="text" id="searchInput" placeholder="Tìm tên người dùng hoặc email..." />
        <select id="roleFilter" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc; margin-right: 10px;">
            <option value="">Tất cả vai trò</option>
            <option value="Admin">Admin</option>
            <option value="Shipper">Shipper</option>
            <option value="User">User</option>
        </select>
        <button class="btn-search">Tìm</button>
        <button class="btn-reset">Làm mới</button>
    </div>

    <div id="message" style="margin-bottom: 15px; display: none; font-weight: 500;"></div>
    <div class="table-wrapper">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Mật khẩu</th>
                <th>Số điện thoại</th>
                <th>Địa chỉ</th>
                <th>Vai trò</th>
                <th>Hồ sơ</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody id="userData">
        </tbody>
    </table>
</div>
</div>

@section Scripts {
    <script>
        function showMessage(text, isSuccess = false) {
            const msgDiv = document.getElementById('message');
            msgDiv.textContent = text;
            msgDiv.style.color = isSuccess ? '#28a745' : '#e53935';
            msgDiv.style.display = 'block';
            setTimeout(() => { msgDiv.style.display = 'none'; }, 3000);
        }

        // Hàm load dữ liệu khách hàng
        async function fetchUsers() {
            try {
                const role = document.getElementById('roleFilter').value;
                const searchKeyword = document.getElementById('searchInput').value.trim().toLowerCase();

                const url = role ? `/api/user?role=${role}` : '/api/user';
                const response = await fetch(url);
                if (!response.ok) throw new Error(`Lỗi HTTP: ${response.status}`);

                let users = await response.json();

                if (searchKeyword) {
                    users = users.filter(u => 
                        (u.fullName && u.fullName.toLowerCase().includes(searchKeyword)) ||
                        (u.email && u.email.toLowerCase().includes(searchKeyword))
                    );
                }
                const tableBody = document.getElementById('userData');

                if (!users || users.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="9" style="text-align: center;">Chưa có khách hàng nào!</td></tr>';
                    return;
                }

                tableBody.innerHTML = users.map(u => {
                    // Hiển thị trực tiếp chuỗi mật khẩu đã băm (cắt ngắn 20 ký tự đầu và hiện đầy đủ khi di chuột)
                    const passDisplay = u.password ? `<span title="${u.password}">${u.password.substring(0, 20)}...</span>` : "N/A";
                    return `
                    <tr>
                        <td>${u.id}</td>
                        <td><strong>${u.fullName || "Không tên"}</strong></td>
                        <td>${u.email || "N/A"}</td>
                        <td>${passDisplay}</td>
                        <td>${u.phone || "N/A"}</td>
                        <td>${(u.address || "").substring(0, 30)}</td>
                        <td><strong>${u.role || "User"}</strong></td>
                        <td>
                           <span class="badge ${u.isProfileCompleted ? "badge-success" : "badge-danger"}">
                                ${u.isProfileCompleted ? "Hoàn tất" : "Chưa hoàn tất"}
                           </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-edit" onclick="location.href='/User/Edit/${u.id}'"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="btn-delete" onclick="deleteUser(${u.id})"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    `;
                }).join('');

            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('userData').innerHTML =
                    `<tr><td colspan="9" style="color:red; text-align: center;">Lỗi kết nối API. Vui lòng kiểm tra lại server.</td></tr>`;
            }
        }

        // Hàm xóa khách hàng
        async function deleteUser(id) {
            if (!confirm("Xác nhận xóa khách hàng này?")) return;
            try {
                const response = await fetch(`/api/user/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    showMessage("Đã xóa thành công!", true);
                    fetchUsers(); // Tự động load lại bảng sau khi xóa
                } else {
                    showMessage("Xóa thất bại!");
                }
            } catch (error) {
                console.error("Lỗi xóa:", error);
            }
        }

        // Tự động chạy hàm fetchUsers khi trang load xong
        document.addEventListener("DOMContentLoaded", fetchUsers);

        // Lắng nghe sự kiện thay đổi thanh chọn Vai trò
        document.getElementById('roleFilter').addEventListener('change', fetchUsers);

        // Lắng nghe sự kiện click vào nút Tìm kiếm
        document.querySelector('.btn-search').addEventListener('click', fetchUsers);

        // Lắng nghe sự kiện gõ phím Enter trong ô tìm kiếm
        document.getElementById('searchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') fetchUsers();
        });

        // Xử lý nút Làm mới (Reset)
        document.querySelector('.btn-reset').addEventListener('click', function () {
            document.getElementById('roleFilter').value = '';
            document.getElementById('searchInput').value = '';
            fetchUsers();
        });
    </script>
}
