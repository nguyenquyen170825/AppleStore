@{
    Layout = "_Layout";
    ViewData["HideFooter"] = true;
}
@section Styles {
    <link rel="stylesheet" href="~/css/home/User/Register.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .otp-inputs {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin: 30px 0;
        }
        .otp-box {
            width: 45px;
            height: 55px;
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            border: 1px solid #e5e5e7;
            border-radius: 12px;
            background: #f5f5f7;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .otp-box:focus {
            background: #fff;
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }
        .timer-container {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #86868b;
        }
        #timer {
            font-weight: 600;
            color: #0071e3;
        }
        .resend-btn {
            border: none;
            background: none;
            color: #0071e3;
            font-weight: 600;
            cursor: pointer;
            padding: 0;
            font-size: 14px;
            display: none;
        }
        .resend-btn:disabled {
            color: #b6b6bb;
            cursor: not-allowed;
        }
    </style>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error animated-fade-in" style="background: rgba(255, 59, 48, 0.1); color: #ff3b30; padding: 15px; border-radius: 12px; margin-bottom: 20px; text-align: center; font-size: 14px; border: 1px solid rgba(255, 59, 48, 0.2);">
        <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="page-wrapper animated-fade-in">
    <div class="register-container animated-scale-in">
        <div class="auth-card">
            <div class="otp-instruction">
                <i class="fa-solid fa-shield-halved"></i>
                <h1 class="title">Xác minh email</h1>
                <p class="subtitle">Chúng tôi đã gửi mã xác nhận đến <br> <strong>@ViewBag.Email</strong></p>
            </div>

            <form asp-controller="Register" asp-action="VerifyOtp" method="post" id="otpForm">
                <input type="hidden" name="email" value="@ViewBag.Email" />
                <input type="hidden" name="otp" id="fullOtp" />
                
                <div class="otp-inputs">
                    <input type="text" maxlength="1" class="otp-box" required autofocus>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                </div>

                <button type="submit" class="btn-submit animated-press">Xác nhận</button>
            </form>
            
            <div class="timer-container">
                <span id="timer-text">Gửi lại mã sau <span id="timer">60</span>s</span>
                <button type="button" class="resend-btn animated-underline" onclick="resendOtp()" id="resendBtn">Gửi lại mã ngay</button>
            </div>

            <p class="bottom-text" style="margin-top: 24px;">
                <a asp-controller="Home" asp-action="Register" class="animated-underline">Quay lại trang đăng ký</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const inputs = document.querySelectorAll('.otp-box');
        const fullOtpInput = document.getElementById('fullOtp');
        const otpForm = document.getElementById('otpForm');

        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                updateFullOtp();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && e.target.value === '' && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        function updateFullOtp() {
            let otp = '';
            inputs.forEach(input => otp += input.value);
            fullOtpInput.value = otp;
        }

        // Timer logic
        let timeLeft = 60;
        const timerSpan = document.getElementById('timer');
        const timerText = document.getElementById('timer-text');
        const resendBtn = document.getElementById('resendBtn');

        const countdown = setInterval(() => {
            timeLeft--;
            timerSpan.textContent = timeLeft;
            if (timeLeft <= 60) {
                clearInterval(countdown);
                timerText.style.display = 'none';
                resendBtn.style.display = 'inline-block';
            }
        }, 1000);

        function resendOtp() {
            // Thực tế bạn có thể gọi AJAX hoặc submit form ẩn để gửi lại
            const email = '@ViewBag.Email';
            window.location.href = `/Register/ResendOtp?email=${email}`;
        }
    </script>
}
