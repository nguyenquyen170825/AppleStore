@{
    Layout = "_Layout";
    ViewData["HideFooter"] = true;
}
@section Styles {
    <link rel="stylesheet" href="~/css/home/User/Login.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
}

<div class="page-wrapper animated-fade-in">
    <div class="login-container animated-scale-in">
    

        <div class="auth-card">
            <h1 class="title">Đăng nhập</h1>
            <p class="subtitle">Chào mừng bạn quay lại</p>

            <form method="post" asp-controller="Login" asp-action="Login">
                <div class="form-group">
                    <label>EMAIL</label>
                    <div class="input-group">
                        <i class="fa-solid fa-envelope icon-prefix"></i>
                        <input type="text" name="email" placeholder="name@example.com">
                    </div>
                </div>

                <div class="form-group">
                    <label>MẬT KHẨU</label>
                    <div class="input-group">
                        <i class="fa-solid fa-lock icon-prefix"></i>
                        <input type="password" name="password" placeholder="••••••••">
                        <i class="fa-solid fa-eye eye-toggle animated-hover" onclick="const input = this.previousElementSibling; if (input.type === 'password') { input.type = 'text'; this.classList.remove('fa-eye'); this.classList.add('fa-eye-slash'); } else { input.type = 'password'; this.classList.remove('fa-eye-slash'); this.classList.add('fa-eye'); }"></i>
                    </div>
                </div>

                <div class="form-options">
                    <label class="remember-me animated-hover">
                        <input type="checkbox">
                        <span class="checkmark"></span>
                        <span>Ghi nhớ đăng nhập</span>
                    </label>
                    <a asp-controller="Login" asp-action="ForgotPassword" class="forgot-pass animated-underline">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-submit animated-press">Đăng nhập</button>
            </form>

            <div class="separator">
                <span>HOẶC ĐĂNG NHẬP BẰNG</span>
            </div>

            <div class="social-actions">
                <a asp-controller="Login" asp-action="ExternalLogin" asp-route-provider="Google" class="social-btn google animated-hover animated-press" style="text-decoration: none; display: flex; justify-content: center; align-items: center;color:black;">
                    <img src="https://www.gstatic.com/images/branding/product/1x/googleg_48dp.png" alt="Google">
                    Google
                </a>
                <a asp-controller="Login" asp-action="ExternalLogin" asp-route-provider="Facebook" class="social-btn facebook animated-hover animated-press" style="text-decoration: none; display: flex; justify-content: center; align-items: center;color:black;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg" alt="Facebook">
                    Facebook
                </a>
            </div>
        </div>
        <p class="bottom-text">
            Chưa có tài khoản? <a asp-controller="Home" asp-action="Register" class="animated-underline">Đăng ký ngay</a>
        </p>
    </div>
</div>