@section Styles{
    <link rel="stylesheet" href="~/css/home/User/Login.css" asp-append-version="true">
}
<div class="login-container">
<div class="login-img">
        <img src="~/image/undraw_secure-password_9qv4.svg" alt="">
    </div>
    <div class="login-box">
        <h2>Đăng nhập</h2>
        <p>Sử dụng tài khoản Apple Store của bạn</p>
        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="input-group">
                <input type="email" id="email" name="email" required placeholder=" ">
                <label for="email">Email hoặc Số điện thoại</label>
            </div>

            <div class="input-group">
                <input type="password" id="password" name="password" required placeholder=" ">
                <label for="password">Mật khẩu</label>
            </div>

            <div class="options">
                <label><input type="checkbox"> Ghi nhớ đăng nhập</label>
                <a href="#">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-login">Đăng nhập</button>
        </form>

        <div class="register-link">
            Chưa có tài khoản? <a asp-action="Register">Tạo tài khoản ngay</a>
        </div>
    </div>
    
</div>
