@{
    Layout = "_Layout";
    ViewData["HideFooter"] = true;
}
@section Styles {
    <link rel="stylesheet" href="~/css/home/User/Login.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
}

<div class="page-wrapper animated-fade-in">
    <div class="login-container animated-scale-in">
        <div class="auth-card">
            <h1 class="title">Quên mật khẩu?</h1>
            <p class="subtitle">Đừng lo lắng, chúng tôi sẽ gửi mã khôi phục cho bạn.</p>

            <form method="post" asp-controller="Login" asp-action="ForgotPassword">
                <div class="form-group">
                    <label>EMAIL CỦA BẠN</label>
                    <div class="input-group">
                        <i class="fa-solid fa-envelope icon-prefix"></i>
                        <input type="email" name="email" placeholder="name@example.com" required>
                    </div>
                </div>

                <div style="margin-top: 30px;">
                    <button type="submit" class="btn-submit animated-press">Gửi mã xác nhận</button>
                </div>
                
                <p class="bottom-text" style="margin-top: 24px;">
                    <a asp-controller="Home" asp-action="Login" class="animated-underline">Quay lại trang đăng nhập</a>
                </p>
            </form>
        </div>
    </div>
</div>
