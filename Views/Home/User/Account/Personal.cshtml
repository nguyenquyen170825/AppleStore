@model DUANCUAHANGAPPLE.Models.User

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/home/User/Personal.css" />
}

<div class="personal-wrapper">
    <div class="personal-container">

        <!-- SIDEBAR -->
        <aside class="personal-sidebar">
            <div class="sidebar-header">
                <h2>Quản lý khách hàng</h2>
                <p>Hệ thống Digital Atelier</p>
            </div>
            
            <nav class="sidebar-menu">
                <a href="#overview" class="sidebar-link active">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                    <span class="link-text">Tổng quan</span>
                </a>
                <a href="#profile" class="sidebar-link">
                    <span class="material-symbols-outlined">person</span>
                    <span class="link-text">Thông tin tài khoản</span>
                </a>
                <a href="#order" class="sidebar-link">
                    <span class="material-symbols-outlined">receipt_long</span>
                    <span class="link-text">Lịch sử mua hàng</span>
                </a>
                
                
                <a href="#warranty" class="sidebar-link">
                    <span class="material-symbols-outlined">security</span>
                    <span class="link-text">Tra cứu bảo hành</span>
                </a>
                <a href="#membership" class="sidebar-link">
                    <span class="material-symbols-outlined">card_membership</span>
                    <span class="link-text">Hạng thành viên & ưu đãi</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="sidebar-link">
                    <span class="material-symbols-outlined">support_agent</span>
                    <span class="link-text">Hỗ trợ kỹ thuật</span>
                </a>
                <form asp-controller="Login" asp-action="Logout" method="post" style="margin: 0;">
                    <button type="submit" class="logout-btn">
                        <span class="material-symbols-outlined">logout</span>
                        <span class="link-text">Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="personal-main">
            <!-- TỔNG QUAN -->
            <section id="overview" class="personal-content">
                <!-- User Profile Bento Grid -->
                <div class="bento-grid">
                    <!-- User Info Card -->
                    <div class="card user-info-card">
                        <div class="avatar-ring">
                            <img alt="Avatar" src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName ?? "User"))&size=200&background=random"/>
                        </div>
                        <h3>@Model.FullName</h3>
                        <p class="phone">@Model.Phone</p>
                        <div class="member-rank">Hạng thành viên: S-NULL</div>
                        <p class="last-update">
                            <span class="material-symbols-outlined">update</span>
                            Cập nhật lần cuối: @DateTime.Now.ToString("dd/MM/yyyy")
                        </p>
                    </div>

                    <!-- Stats and Progress Card -->
                    <div class="card stats-card">
                        <div class="stats-grid">
                            <div class="stat-item">
                                <p class="stat-label">Tổng số đơn hàng</p>
                                <p class="stat-value">0</p>
                            </div>
                            <div class="stat-item">
                                <p class="stat-label">Tổng tiền tích lũy</p>
                                <p class="stat-value text-primary">0đ</p>
                            </div>
                        </div>
                        <div class="progress-section">
                            <div class="progress-header">
                                <span class="progress-title">Tiến trình lên hạng S-NEW</span>
                                <span class="progress-fraction">0 / 5.000.000đ</span>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar-fill" style="width: 0%"></div>
                            </div>
                            <p class="progress-note">Bạn cần tích lũy thêm 5.000.000đ để thăng hạng.</p>
                        </div>
                    </div>
                </div>

                <!-- Banner Section -->
                <div class="banner-grid">
                    <div class="banner-card banner-blue">
                        <div class="banner-info">
                            <h4>S-Student</h4>
                            <p>Ưu đãi dành cho Sinh viên</p>
                        </div>
                        <span class="material-symbols-outlined banner-icon">school</span>
                    </div>
                    <div class="banner-card banner-red">
                        <div class="banner-info">
                            <h4>S-Business</h4>
                            <p>Giải pháp cho doanh nghiệp</p>
                        </div>
                        <span class="material-symbols-outlined banner-icon">business_center</span>
                    </div>
                    <div class="banner-card banner-dark">
                        <div class="banner-info">
                            <h4>Địa chỉ nhận hàng</h4>
                            <p>Thêm địa chỉ giao hàng</p>
                        </div>
                        <span class="material-symbols-outlined banner-icon">location_on</span>
                    </div>
                </div>

                <!-- Bottom Sections -->
                <div class="bottom-grid">
                    <div class="card bottom-card">
                        <div class="card-icon-wrapper">
                            <img alt="No orders" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDzw6RPS5mWRkNDrtDsrXjdCm-aI_GCOMUTrZehVGEdDO9UCgGpqusnx5gWiksfiCua-qaPTQUrU36TgrHd4s6qbFLGLN2nsz_PEDXtFOb3OuZJ71HDYcPGB0ckoz3xhoXprT8Lyu7n6ZN--RyJvNJ26MNFwV4idsIUdEHwdr5CSIakinBd4GI-q3T-nNM4vCSQxHw705ZZm7Ij6jUCGedkWNROiZRwym_zFbpNySEg0wYGR8M8QMDbLyQXbkmVbYYBOj5seyaxaR4"/>
                        </div>
                        <h4>Đơn hàng gần đây</h4>
                        <p>Bạn chưa có đơn hàng nào trong thời gian gần đây.</p>
                        <button class="btn btn-primary">Mua sắm ngay</button>
                    </div>
                    <div class="card bottom-card">
                        <div class="card-icon-wrapper">
                            <img alt="No rewards" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCOgOiCqASjh64tJ7ZeAMh-wfrGs8b8pPcF-_0NV4WkYZTVUt5FMvPZa_y1vhflHpdaBLrbr74eN5q6wK_qDHlEgUOcUNElVpdX9qKitKZMoOK7wGKBXUEcH5cUT-x6fYppHjTQttb0sNxqhPLKU_nUKV_9_afAa1iaNNaseEtcVqBCGgJapHVihRU-VRcG0-M_CJkGmzKWZwG9Kn_oTY1-5qxTqw11hQS6jYStFySTh66UMn7A9SMaNuemsflRQD0J7TPdVFpQCi8"/>
                        </div>
                        <h4>Ưu đãi của bạn</h4>
                        <p>Khám phá những đặc quyền dành riêng cho bạn.</p>
                        <button class="btn btn-secondary">Xem tất cả</button>
                    </div>
                </div>
            </section>

            <!-- PROFILE (THÔNG TIN TÀI KHOẢN) -->
            <section id="profile" class="personal-content" style="display:none">
                <!-- Thông tin cá nhân -->
                <div class="card mb-4" style="margin-bottom: 1.5rem;">
                    <div class="card-header-flex">
                        <h3 class="card-title">Thông tin cá nhân</h3>
                        <button id="btnUpdateProfile" class="btn-text text-primary">
                            <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 4px;">edit_square</span>
                            Cập nhật
                        </button>
                    </div>
                    
                    <div class="personal-info-layout">
                        <!-- Cột Avatar -->
                        <div class="avatar-col">
                            <div class="avatar-wrapper">
                                <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName ?? "User"))&size=150&background=random" alt="Avatar" id="profileAvatar" />
                                <label for="avatarUpload" class="avatar-edit-btn">
                                    <span class="material-symbols-outlined">photo_camera</span>
                                </label>
                                <input type="file" id="avatarUpload" style="display: none;" accept="image/*" />
                            </div>
                            <p class="avatar-hint">Bấm vào để đổi <br/>ảnh đại diện</p>
                        </div>
                        
                        <!-- Cột Thông tin -->
                        <div class="info-col">
                            <div class="info-grid">
                                <div class="info-item">
                                    <span class="info-label">Họ và tên:</span>
                                    <span class="info-value">@Model.FullName</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Số điện thoại:</span>
                                    <span class="info-value">@Model.Phone</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Giới tính:</span>
                                    <span class="info-value">-</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Email:</span>
                                    <span class="info-value">@Model.Email</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Ngày sinh:</span>
                                    <span class="info-value">17/08/2005</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Địa chỉ mặc định:</span>
                                    <span class="info-value">@(string.IsNullOrEmpty(Model.Address) ? "-" : Model.Address)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sổ địa chỉ -->
                <div class="card mb-4" style="margin-bottom: 1.5rem;">
                    <div class="card-header-flex">
                        <h3 class="card-title">Sổ địa chỉ</h3>
                        <button class="btn-text text-primary">
                            <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 4px;">add</span>
                            Thêm địa chỉ
                        </button>
                    </div>
                    
                    <div class="empty-state">
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDzw6RPS5mWRkNDrtDsrXjdCm-aI_GCOMUTrZehVGEdDO9UCgGpqusnx5gWiksfiCua-qaPTQUrU36TgrHd4s6qbFLGLN2nsz_PEDXtFOb3OuZJ71HDYcPGB0ckoz3xhoXprT8Lyu7n6ZN--RyJvNJ26MNFwV4idsIUdEHwdr5CSIakinBd4GI-q3T-nNM4vCSQxHw705ZZm7Ij6jUCGedkWNROiZRwym_zFbpNySEg0wYGR8M8QMDbLyQXbkmVbYYBOj5seyaxaR4" alt="No address" />
                        <p>Bạn chưa có địa chỉ nào được tạo</p>
                    </div>
                </div>

                <!-- Footer row: Password & Linked Accounts -->
                <div class="profile-bottom-grid">
                    <!-- Password -->
                    <div class="card">
                        <div class="card-header-flex" style="border-bottom: none; padding-bottom: 0; margin-bottom: 1.5rem;">
                            <h3 class="card-title">Mật khẩu</h3>
                            <button id="btnUpdatePassword" class="btn-text text-primary">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 4px;">edit_square</span>
                                Thay đổi mật khẩu
                            </button>
                        </div>
                        <div class="password-info" style="margin-top: 0;">
                            <span class="info-label">Cập nhật lần cuối lúc:</span>
                            <span class="info-value">@(Model.PasswordLastUpdated?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</span>
                        </div>
                    </div>

                    <!-- Linked Accounts -->
                    <div class="card">
                        <div class="card-header-flex" style="border-bottom: none; padding-bottom: 0; margin-bottom: 1.5rem;">
                            <h3 class="card-title">Tài khoản liên kết</h3>
                        </div>
                        <div class="linked-acc-list">
                            <div class="linked-acc-item">
                                <div class="linked-acc-info">
                                    <img src="https://img.icons8.com/color/48/google-logo.png" alt="Google" class="acc-icon" />
                                    <span class="acc-name">Google</span>
                                    <span class="badge badge-success">Đã liên kết</span>
                                </div>
                                <button class="btn-text text-secondary">
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 4px;">link_off</span>
                                    Hủy liên kết
                                </button>
                            </div>
                            
                            <div class="linked-acc-item" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                                <div class="linked-acc-info">
                                    <img src="https://img.icons8.com/color/48/zalo.png" alt="Zalo" class="acc-icon" style="width: 24px; height: 24px;" />
                                    <span class="acc-name">Zalo</span>
                                </div>
                                <button class="btn-text text-primary">
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 4px;">link</span>
                                    Liên kết
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ORDER (LỊCH SỬ MUA HÀNG) -->
            <section id="order" class="personal-content" style="display:none">
                <div class="card">
                    <div class="order-header">
                        <div>
                            <h2>Đơn hàng của bạn</h2>
                            <p>Quản lý và theo dõi tiến trình các đơn hàng.</p>
                        </div>
                        <input class="order-search" placeholder="Tìm theo mã đơn hàng..." />
                    </div>
                    <div class="order-filter">
                        <button class="active">Tất cả</button>
                        <button>Đang xử lý</button>
                        <button>Đang giao</button>
                        <button>Hoàn thành</button>
                        <button>Đã huỷ</button>
                    </div>
                    <div class="order-list">
                        <div class="order-card">
                            <div class="order-top">
                                <div>
                                    <div class="order-id-status">
                                        <span class="order-id">#APL8821</span>
                                        <span class="status shipping">Đang giao</span>
                                    </div>
                                    <span class="order-date">Đặt ngày 24 tháng 10, 2023</span>
                                </div>
                                <div class="order-total">
                                    <span>Tổng tiền</span>
                                    <strong>32.990.000₫</strong>
                                </div>
                            </div>
                            <div class="order-products">
                                <div class="order-product">
                                    <img src="/images/iphone.png" onerror="this.src='https://placehold.co/65'">
                                    <div>
                                        <h4>iPhone 15 Pro Max</h4>
                                        <p>Titan Tự Nhiên, 256GB</p>
                                    </div>
                                </div>
                                <div class="order-product">
                                    <img src="/images/case.png" onerror="this.src='https://placehold.co/65'">
                                    <div>
                                        <h4>Ốp lưng MagSafe</h4>
                                        <p>Trong suốt</p>
                                    </div>
                                </div>
                                <button class="btn btn-outline order-detail-btn">Xem chi tiết</button>
                            </div>
                        </div>
                    </div>
                    <div class="order-loadmore">
                        Tải thêm đơn hàng cũ ⌄
                    </div>
                </div>
            </section>



            <!-- TRA CỨU BẢO HÀNH -->
            <section id="warranty" class="personal-content" style="display:none">
                <div class="card">
                    <div class="warranty-header">
                        <h2 style="margin-top:0; margin-bottom: 0.5rem">Tra cứu bảo hành</h2>
                        <p>Kiểm tra thời gian và trạng thái bảo hành thiết bị của bạn.</p>
                    </div>
                    
                    <div class="warranty-form">
                        <input type="text" placeholder="Nhập số điện thoại, IMEI hoặc Serial Number..." class="warranty-input" />
                        <button class="btn btn-primary warranty-btn">Tra cứu</button>
                    </div>

                    <div class="warranty-result-empty">
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDzw6RPS5mWRkNDrtDsrXjdCm-aI_GCOMUTrZehVGEdDO9UCgGpqusnx5gWiksfiCua-qaPTQUrU36TgrHd4s6qbFLGLN2nsz_PEDXtFOb3OuZJ71HDYcPGB0ckoz3xhoXprT8Lyu7n6ZN--RyJvNJ26MNFwV4idsIUdEHwdr5CSIakinBd4GI-q3T-nNM4vCSQxHw705ZZm7Ij6jUCGedkWNROiZRwym_zFbpNySEg0wYGR8M8QMDbLyQXbkmVbYYBOj5seyaxaR4" alt="No data" />
                        <p>Nhập thông tin thiết bị để bắt đầu tra cứu</p>
                    </div>
                </div>
            </section>

            <!-- HẠNG THÀNH VIÊN VÀ ƯU ĐÃI -->
            <section id="membership" class="personal-content" style="display:none">
                <div class="card membership-hero">
                    <div class="membership-info">
                        <h2>Hạng thành viên: S-NULL</h2>
                        <p>Bạn đang ở điểm khởi đầu. Mua sắm thêm để nhận vô vàn đặc quyền!</p>
                        <div class="points-badge">0 S-Point</div>
                    </div>
                    <div class="membership-progress-wrap">
                        <div class="progress-header">
                            <span class="progress-title text-white">Tiến trình lên S-NEW</span>
                            <span class="progress-fraction text-white">0 / 5.000.000đ</span>
                        </div>
                        <div class="progress-bar-container dark-bg">
                            <div class="progress-bar-fill white-fill" style="width: 0%"></div>
                        </div>
                        <p class="progress-note text-white-50">Tích lũy tối thiểu 5.000.000đ để đạt hạng tiếp theo.</p>
                    </div>
                </div>

                <div class="rewards-section">
                    <h3 class="rewards-title">Ưu đãi của bạn</h3>
                    <div class="rewards-grid">
                        <div class="reward-card empty-reward">
                            <span class="material-symbols-outlined empty-icon">sentiment_dissatisfied</span>
                            <p>Bạn chưa có mã ưu đãi nào!</p>
                        </div>
                    </div>
                </div>
            </section>


            <!-- CẬP NHẬT THÔNG TIN MODAL -->
            <div id="updateProfileModal" class="modal-overlay" style="display:none;">
                <div class="modal-content-box">
                    <div class="modal-header">
                        <h3 style="margin:0;">Cập nhật thông tin</h3>
                        <button id="closeProfileModal" class="btn-close-modal">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="updateProfileForm" method="post" asp-controller="Profile" asp-action="CompleteProfile">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Họ và tên</label>
                                    <input type="text" name="FullName" value="@Model.FullName" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label>Số điện thoại</label>
                                    <input type="text" name="Phone" value="@Model.Phone" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label>Giới tính</label>
                                    <select name="Sex" class="form-control">
                                        <option value="">Chọn giới tính</option>
                                        <option value="Nam">Nam</option>
                                        <option value="Nu">Nữ</option>
                                        <option value="Khac">Khác</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Ngày sinh</label>
                                    <input type="date" name="NgaySinh" class="form-control" value="@(Model.NgaySinh?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Email (Không thể thay đổi)</label>
                                    <input type="email" name="Email" value="@Model.Email" class="form-control" readonly style="background-color: var(--surface-high); cursor: not-allowed;" />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Địa chỉ mặc định</label>
                                    <input type="text" name="Address" value="@Model.Address" class="form-control" />
                                </div>
                            </div>
                            <div class="modal-footer" style="margin-top: 1.5rem; text-align: right;">
                                <button type="button" id="cancelProfileBtn" class="btn btn-secondary" style="margin-right: 0.5rem;">Hủy</button>
                                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- CẬP NHẬT MẬT KHẨU MODAL -->
            <div id="updatePasswordModal" class="modal-overlay" style="display:none;">
                <div class="modal-content-box" style="max-width: 450px;">
                    <div class="modal-header">
                        <h3 style="margin:0;">Thay đổi mật khẩu</h3>
                        <button type="button" id="closePasswordModal" class="btn-close-modal">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="updatePasswordForm" method="post" asp-controller="Profile" asp-action="ResetPassword">
                            <div class="form-grid">
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Mật khẩu cũ</label>
                                    <input type="password" name="oldPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại..." required />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Mật khẩu mới</label>
                                    <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới..." required />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Xác nhận mật khẩu mới</label>
                                    <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới..." required />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Mã OTP</label>
                                    <input type="text" name="otp" class="form-control" placeholder="Nhập mã OTP..." required />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <button type="button" id="sendOtpBtn" class="btn btn-primary">Gửi mã OTP</button>
                                </div>
                            </div>
                            <div class="modal-footer" style="margin-top: 1.5rem; text-align: right;">
                                <button type="button" id="cancelPasswordBtn" class="btn btn-secondary" style="margin-right: 0.5rem;">Hủy</button>
                                <button type="submit" class="btn btn-primary">Xác nhận Lưu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            showToast('@TempData["ErrorMessage"]', true);
        </script>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            showToast('@TempData["SuccessMessage"]');
        </script>
    }
    <script>
        $(document).ready(function () {
            // Hide all content sections initially
            $('.personal-content').hide();

            // Show overview initially
            $('#overview').show();

            // Modal Logic
            $('#btnUpdateProfile').on('click', function() {
                $('#updateProfileModal').fadeIn('fast');
                $('body').css('overflow', 'hidden'); // Prevent background scroll
            });

            $('#closeProfileModal, #cancelProfileBtn').on('click', function() {
                $('#updateProfileModal').fadeOut('fast');
                $('body').css('overflow', 'auto');
            });
            
            // Mở Modal Đổi mật khẩu
            $('#btnUpdatePassword').on('click', function() {
                $('#updatePasswordModal').fadeIn('fast');
                $('body').css('overflow', 'hidden'); 
            });

            // Đóng Modal Đổi mật khẩu
            $('#closePasswordModal, #cancelPasswordBtn').on('click', function() {
                $('#updatePasswordModal').fadeOut('fast');
                $('body').css('overflow', 'auto');
            });
            
            // Close ANY modal when clicking outside background
            $('.modal-overlay').on('click', function(e) {
                if(e.target === this) {
                    $(this).fadeOut('fast');
                    $('body').css('overflow', 'auto');
                }
            });

            // Handle sidebar link clicks
            $('.sidebar-menu a').on('click', function (e) {
                e.preventDefault();

                // Remove active class from all links and add to the clicked link
                $('.sidebar-menu a').removeClass('active');
                $(this).addClass('active');

                // Hide all content sections and show the selected one
                $('.personal-content').hide();
                $($(this).attr('href')).fadeIn();
            });

            // Handle Avatar Image Preview
            $('#avatarUpload').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#profileAvatar').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(file);
                }
            });
        });
        document.getElementById("sendOtpBtn").addEventListener("click", function () {
            const email = '@Model.Email';

            fetch(`/Profile/SendOtp?email=${encodeURIComponent(email)}`, {
                method: "POST"
            })
            .then(response => response.json())
            .then(data => {
                if (data.message) {
                    showToast(data.message);
                } else {
                    showToast("Gửi mã OTP thất bại", true);
                }
            })
            .catch(err => {
                showToast("Lỗi kết nối server", true);
            });
        });
    </script>
}
