@{
    Layout = "_Layout";
    ViewData["HideFooter"] = true;
}
@section Styles {
    <link rel="stylesheet" href="~/css/home/User/Register.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .otp-inputs {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin: 30px 0;
        }
        .otp-box {
            width: 45px;
            height: 55px;
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            border: 1px solid #e5e5e7;
            border-radius: 12px;
            background: #f5f5f7;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .otp-box:focus {
            background: #fff;
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }
    </style>
}

<div class="page-wrapper animated-fade-in">
    <div class="register-container animated-scale-in">
        <div class="auth-card">
            <div class="otp-instruction">
                <i class="fa-solid fa-key" style="font-size: 40px; color: #0071e3; margin-bottom: 16px; display: block; text-align: center;"></i>
                <h1 class="title">Xác minh yêu cầu</h1>
                <p class="subtitle" style="text-align: center;">Nhập mã 6 chữ số vừa được gửi đến <br> <strong>@ViewBag.Email</strong></p>
            </div>

            <form asp-controller="Login" asp-action="VerifyForgotPasswordOtp" method="post" id="otpForm">
                <input type="hidden" name="email" value="@ViewBag.Email" />
                <input type="hidden" name="otp" id="fullOtp" />
                
                <div class="otp-inputs">
                    <input type="text" maxlength="1" class="otp-box" required autofocus>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                    <input type="text" maxlength="1" class="otp-box" required>
                </div>

                <button type="submit" class="btn-submit animated-press">Tiếp tục</button>
            </form>
            
            <p class="bottom-text" style="margin-top: 24px; text-align: center;">
                <a asp-controller="Login" asp-action="ForgotPassword" class="animated-underline">Quay lại trang nhập email</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const inputs = document.querySelectorAll('.otp-box');
        const fullOtpInput = document.getElementById('fullOtp');

        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                updateFullOtp();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && e.target.value === '' && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        function updateFullOtp() {
            let otp = '';
            inputs.forEach(input => otp += input.value);
            fullOtpInput.value = otp;
        }
    </script>
}
