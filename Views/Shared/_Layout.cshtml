<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DUANCUAHANGAPPLE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DUANCUAHANGAPPLE.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <header class="header">
        <div class="nav-brand">
            <a asp-area="" asp-controller="Home" asp-action="Index">CUAHANG APPPLE</a>
        </div>
        <nav class="nav-menu">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
            <div class="menu-category" id="menu-category">
                <button id="btnCategory">Danh mục</button>
                <div id="categoryDropdown">
                    @await Component.InvokeAsync("Menudanhmuc")
                </div>
            </div>
            <a asp-controller="Home" asp-action="Privacy">Chính sách</a>
        </nav> 
        <div class="nav-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="search"  placeholder="Bạn muốn gì cho ngày hôm nay ?">
        </div>
        <div class="nav-actions">
            <!-- Giỏ hàng - luôn hiện -->
            <a class="nav-cart" id="navCartBtn" asp-controller="Cart" asp-action="GioHang" title="Giỏ hàng">
                <i class="fa-solid fa-shopping-cart"></i>
                <span class="cart-badge" id="cartBadge" style="display:none;">0</span>
            </a>

            <!-- Kiểm tra đăng nhập -->
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <!-- Đã đăng nhập: hiện tên + avatar -->
                <a class="nav-user nav-user-logged" asp-controller="Profile" asp-action="Personal" title="Tài khoản">
                    <span class="nav-user-avatar">
                        <i class="fa-solid fa-user"></i>
                    </span>
                    <span class="nav-user-name">@(User.FindFirst("FullName")?.Value)</span>
                </a>
            }
            else
            {
                <!-- Chưa đăng nhập: nút Đăng nhập -->
                <a class="nav-user nav-user-guest" asp-controller="Home" asp-action="Login" title="Đăng nhập">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Đăng nhập</span>
                </a>
            }
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    @if (ViewData["HideFooter"] == null)
    {
        <footer class="footer">
            <div class="footer-container">

                <div class="footer-grid">

                    <!-- Giới thiệu -->
                    <div class="footer-col">
                        <h2 class="logo">Apple Store</h2>
                        <p class="footer-text">
                            Chuyên cung cấp iPhone chính hãng, giá tốt, bảo hành uy tín.
                        </p>
                        <p>Trải nghiệm công nghệ đỉnh cao với dịch vụ chăm sóc khách hàng tận tâm.</p>
                    </div>

                    <!-- Danh mục -->
                    <div class="footer-col">
                        <h3>Danh mục</h3>
                        <ul>

                        </ul>
                    </div>
                    <!-- Hỗ trợ -->
                    <div class="footer-col">
                        <h3>Hỗ trợ</h3>
                        <ul>
                            <li><a href="#">Hướng dẫn mua hàng</a></li>
                            <li><a href="#">Chính sách bảo hành</a></li>
                            <li><a href="#">Chính sách đổi trả</a></li>
                            <li><a href="#">Liên hệ hỗ trợ</a></li>
                        </ul>
                    </div>

                    <!-- Liên hệ -->
                    <div class="footer-col">
                        <h3>Liên hệ</h3>

                        <p>📍 Ngõ 59 Phạm Văn Đồng, Cầu giấy, Hà Nội</p>
                        <p>📞 0333148620</p>
                        <p>✉ quyenketvl@gmail.com</p>

                        <div class="social">
                            <a href="https://www.facebook.com/share/1CVdXAJcUq/?mibextid=wwXIfr">Facebook</a>
                            <a href="#">Instagram</a>
                            <a href="#">YouTube</a>
                        </div>

                    </div>
                </div>
                <div class="footer-bottom">
                    <p>© 2026 Apple Store - All Rights Reserved.</p>

                    <div class="footer-links">
                        <a href="#">Quyền riêng tư</a>
                        <a href="#">Điều khoản</a>
                        <a href="#">Sitemap</a>
                    </div>
                </div>
            </div>
        </footer>
    }
    <!-- Global Toast Notification -->
    <div id="toastNotification" class="toast-notification">
        <div class="toast-content">
            <i class="fa-solid fa-circle-check"></i>
            <span>Thông báo</span>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
