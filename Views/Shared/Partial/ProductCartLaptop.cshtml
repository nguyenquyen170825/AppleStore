@model List<DUANCUAHANGAPPLE.Models.SanPham>

@foreach (var item in Model)
{
    var firstVariant = item.BienThes?.FirstOrDefault();
    var firstImage = firstVariant?.HinhAnhs?.FirstOrDefault()?.UrlHinhAnh;

    <a asp-controller="Product"
       asp-action="Chitietsanpham"
       asp-route-id="@item.SanPhamId">

        <div class="product-card">

            @* Badge giảm giá *@
            @if (firstVariant?.GiaCu != null && firstVariant.GiaCu > firstVariant.Gia)
            {
                var giamPhanTram =
                (int)((firstVariant.GiaCu.Value - firstVariant.Gia) * 100 / firstVariant.GiaCu.Value);

                <div class="discount-badge">
                    -@giamPhanTram%
                </div>
            }

            <div class="product-image">
                @if (!string.IsNullOrEmpty(firstImage))
                {
                    <img src="@firstImage" />
                }
            </div>

            <div class="product-info">
                <h3>@item.TenSanPham</h3>

                @if (firstVariant != null)
                {
                    if (firstVariant.GiaCu != null)
                    {
                        <div class="price-new">
                            @firstVariant.Gia.ToString("N0")đ
                        </div>

                        <div class="price-old">
                            @firstVariant.GiaCu.Value.ToString("N0")đ
                        </div>
                    }
                    else
                    {
                        <div class="price-new">
                            @firstVariant.Gia.ToString("N0")đ
                        </div>
                    }
                }

                <div class="rating">
                    ⭐⭐⭐⭐⭐ <span>(128)</span>
                </div>

                <button class="btn-cart">Thêm vào giỏ</button>
            </div>

        </div>
    </a>
}