@model List<DUANCUAHANGAPPLE.Models.GioHang>
@{
    var isLogged = User.Identity != null && User.Identity.IsAuthenticated;
}

@if (!isLogged)
{
    <div class="empty-cart-message">
        <div class="empty-icon-wrapper" style="margin-bottom: 20px;">
            <i class="fa-solid fa-user-lock" style="font-size: 80px; color: #d2d2d7;"></i>
        </div>
        <h3>Vui lòng đăng nhập</h3>
        <p>Bạn cần đăng nhập để xem và quản lý giỏ hàng của riêng mình.</p>
        <button class="checkout-btn" style="max-width: 250px; margin: 20px auto 0;" onclick="window.location.href='/Home/Login'">Đăng nhập ngay</button>
    </div>
    return;
}

@if (Model == null || !Model.Any() )
{
    <div class="empty-cart-message">
        <svg style="width:100px;height:100px;fill:#d2d2d7;margin-bottom:20px;" viewBox="0 0 24 24"><path d="M16 6V4C16 1.79 14.21 0 12 0C9.79 0 8 1.79 8 4V6H2C1.45 6 1 6.45 1 7V22C1 23.1 1.9 24 3 24H21C22.1 24 23 23.1 23 22V7C23 6.45 22.55 6 22 6H16ZM10 4C10 2.9 10.9 2 12 2C13.1 2 14 2.9 14 4V6H10V4ZM21 22H3V8H21V22Z"/></svg>
        <h3>Giỏ hàng của bạn đang trống</h3>
        <p>Có vẻ như bạn chưa thêm sản phẩm nào vào giỏ hàng. Hãy khám phá thêm các sản phẩm tuyệt vời của Apple nhé.</p>
        <button class="checkout-btn" style="max-width: 250px; margin: 0 auto;" onclick="window.location.href='/'">Khám phá ngay</button>
    </div>
    return;
}
<div class="cart-layout">
    <div class="cart-products">

        <div class="select-all">
            <div style="display:flex;align-items:center;">
                <input type="checkbox" checked id="selectAllCart" class="check-item" onchange="toggleAll(this)" style="margin-right:12px;" />
                <span style="font-weight:500;">Chọn tất cả</span>
            </div>
            <div class="selected-count">
                Đã chọn: <b id="selectedCount">@Model.Count</b>
            </div>
        </div>
        
        <div class="product">
            @foreach(var items in Model){
            <div class="cart-item">

                <input type="checkbox" checked class="check-item" data-id="@items.BienTheSanPham.BienTheId" onchange="updateSelectAll()"/>
                @if (items.BienTheSanPham != null)
                {
                    <img src="@items.BienTheSanPham.HinhAnhs?.FirstOrDefault()?.UrlHinhAnh" class="product-img" />

                    <div class="product-info">
                        <h3>@items.BienTheSanPham.SanPham?.TenSanPham</h3>
                        <p>@items.BienTheSanPham.Mau</p>
                        <p>@items.BienTheSanPham.DungLuong</p>

                        <div class="quantity">
                            <button onclick="decrease(@items.BienTheId)">
                                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                            <span>@items.SoLuong</span>
                            <button onclick="increase(@items.BienTheId)">
                                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>

                    <div class="product-price">
                        @items.BienTheSanPham.Gia.ToString("N0")đ
                    </div>
                }

                <div class="delete">
                    <button onclick="deleteitems(@items.BienTheId)">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="css-i6dzq1"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    </button>
                </div>
            </div>
            }
        </div>
        <div class="shipping-box">
            <h4>⚡ Vận chuyển: Giao hàng nhanh (Miễn phí)</h4>
            <p>Đơn hàng của bạn sẽ được ưu tiên xử lý ngay và giao hàng miễn phí toàn quốc.</p>
        </div>

    </div>
    
    <div class="order-summary">

        <h2>Tóm tắt đơn hàng</h2>

        <div class="row">
            <span>Tạm tính</span>
            <span>@Model.Sum(x=>x.SoLuong * x.BienTheSanPham.Gia).ToString("N0")đ</span>
        </div>

        <div class="row">
            <span>Phí vận chuyển</span>
            <span class="green">Miễn phí</span>
        </div>

        <div class="row">
            <span>Khuyến mãi</span>
            <span class="red">- 0đ</span>
        </div>

        <hr />

        <div class="total">
            <span>Tổng cộng</span>
            <span>@Model.Sum(x=>x.SoLuong * x.BienTheSanPham.Gia).ToString("N0")đ</span>
        </div>

        <button class="checkout-btn" onclick="checkout()">
            Thanh toán ngay
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" style="margin-left:4px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>

        <button class="continue-btn" onclick="window.location.href='/'">
            Tiếp tục mua sắm
        </button>

    </div>
</div>
<script>
    function loadCart() {
        // Cần truyền hiệu ứng mượt mà khi load lại giỏ hàng
        fetch('/Cart/LoadCart')
            .then(res => res.text())
            .then(html => {
                document.getElementById('cart-container').innerHTML = html;
            });
    }

    function increase(bientheid) {
        fetch(`/Cart/UpdateQuantity?bientheid=${bientheid}&change=1`, {
            method: 'POST'
        })
        .then(() => loadCart());
    }

    function decrease(bientheid) {
        fetch(`/Cart/UpdateQuantity?bientheid=${bientheid}&change=-1`, {
            method: 'POST'
        })
        .then(() => loadCart());
    }

    function deleteitems(bientheid){
        if(confirm("Bạn có chắc chắn muốn xóa sản phẩm này không?")){
            fetch( `/Cart/Delete?bientheid=${bientheid}`,{
                method:'POST'
            }
            ).then(()=>loadCart());
        }
    }

    function toggleAll(source) {
        const items = document.querySelectorAll('.cart-item .check-item');
        items.forEach(item => {
            item.checked = source.checked;
        });
        updateSelectedCount();
    }

    function updateSelectAll() {
        const items = document.querySelectorAll('.cart-item .check-item');
        const selectAll = document.getElementById('selectAllCart');
        const allChecked = Array.from(items).every(item => item.checked);
        
        selectAll.checked = allChecked;
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const selected = document.querySelectorAll('.cart-item .check-item:checked');
        const countEl = document.getElementById('selectedCount');
        if (countEl) {
            countEl.innerText = selected.length;
        }
    }

    function getSelectedIds() {
        const selected = document.querySelectorAll('.cart-item .check-item:checked');
        let ids = [];
        selected.forEach(item => {
            ids.push(item.dataset.id);
        });
        return ids;
    }
    function checkout() {
        const ids = getSelectedIds();
        console.log(ids);
        if (ids.length === 0) {
            showToast("Bạn chưa chọn sản phẩm nào!", true);
            return;
        }

        fetch('/Pay/ThanhToan', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(ids)
        })
        .then(res => {
            if (!res.ok) throw new Error("Lỗi server");
            else{
                showToast("Chọn thanh toán thành công.");
                window.location.href = '/Pay/ThanhToan';
            }
        })
        .catch(err => {
            console.error(err);
            showToast("Thanh toán thất bại!", true);
        });
    }
</script>
